# =======================
# Root-level ignore rules
# =======================
# OS files
.DS_Store
Thumbs.db

# VSCode / IDE
.vscode/
*.code-workspace

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# TypeScript cache
*.tsbuildinfo

# npm/yarn package locks
package-lock.json
yarn.lock

# =======================
# Backend (NestJS / Node)
# =======================
backend/node_modules/
backend/.env
backend/dist/
backend/out/
backend/.cache/
backend/*.tgz

# =======================
# Frontend (React + Vite)
# =======================
frontend/node_modules/
frontend/.env
frontend/dist/
frontend/.vite/
frontend/.cache/
frontend/*.tgz